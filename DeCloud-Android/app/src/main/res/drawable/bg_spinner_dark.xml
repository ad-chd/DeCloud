<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#3A3A3C" />
            <corners android:radius="12dp" />
            <stroke
                android:width="1dp"
                android:color="#48484A" />
            <padding
                android:left="14dp"
                android:right="32dp"
                android:top="8dp"
                android:bottom="8dp" />
        </shape>
    </item>
    <item android:gravity="center_vertical|end" android:right="10dp">
        <rotate
            android:fromDegrees="135"
            android:toDegrees="135"
            android:pivotX="50%"
            android:pivotY="50%">
            <shape android:shape="rectangle">
                <size android:width="8dp" android:height="8dp" />
                <solid android:color="#EBEBF5" />
            </shape>
        </rotate>
    </item>
</layer-list>
