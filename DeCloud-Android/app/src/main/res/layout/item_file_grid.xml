<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/category_card_gap">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/corner_card_secondary"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/surface"
        app:strokeWidth="@dimen/stroke_hairline"
        app:strokeColor="@color/card_stroke">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_xl"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/ivIcon"
                    android:layout_width="@dimen/icon_circle_bg"
                    android:layout_height="@dimen/icon_circle_bg"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_folder_outline"
                    app:tint="@color/folder_icon" />

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Filename"
                    android:textSize="@dimen/text_caption"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/text_primary"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:layout_marginTop="@dimen/space_md" />

                <TextView
                    android:id="@+id/tvSize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1.2 MB"
                    android:textSize="@dimen/text_micro"
                    android:textColor="@color/text_hint"
                    android:maxLines="1"
                    android:gravity="center"
                    android:layout_marginTop="@dimen/space_2xs" />

                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/ivArrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

            </LinearLayout>

            <FrameLayout
                android:id="@+id/checkboxContainer"
                android:layout_width="@dimen/icon_compact"
                android:layout_height="@dimen/icon_compact"
                android:layout_gravity="top|end"
                android:layout_margin="@dimen/space_sm"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/ivCheckBg"
                    android:layout_width="@dimen/icon_standard"
                    android:layout_height="@dimen/icon_standard"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_checkbox_circle" />

                <CheckBox
                    android:id="@+id/checkbox"
                    android:layout_width="@dimen/icon_standard"
                    android:layout_height="@dimen/icon_standard"
                    android:layout_gravity="center"
                    android:buttonTint="@color/primary"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp" />

            </FrameLayout>

        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

</FrameLayout>
