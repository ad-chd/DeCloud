<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/space_3xl"
    android:paddingVertical="@dimen/space_md"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">

    <CheckBox
        android:id="@+id/checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/space_lg"
        android:buttonTint="@color/primary" />

    <ImageView
        android:id="@+id/ivIcon"
        android:layout_width="@dimen/icon_compact"
        android:layout_height="@dimen/icon_compact"
        android:layout_marginEnd="@dimen/space_lg"
        android:src="@drawable/ic_folder_outline"
        app:tint="@color/folder_icon" />

    <TextView
        android:id="@+id/tvName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Filename"
        android:textSize="@dimen/text_body"
        android:fontFamily="sans-serif"
        android:textColor="@color/text_primary"
        android:maxLines="1"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tvSize"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1.2 MB"
        android:textSize="@dimen/text_hint"
        android:textColor="@color/text_hint"
        android:layout_marginStart="@dimen/space_lg" />

    <ImageView
        android:id="@+id/ivArrow"
        android:layout_width="@dimen/icon_sm"
        android:layout_height="@dimen/icon_sm"
        android:src="@drawable/ic_arrow_right"
        android:layout_marginStart="@dimen/space_sm"
        app:tint="@color/text_hint"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />

</LinearLayout>
